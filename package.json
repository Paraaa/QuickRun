{
  "name": "quickrun",
  "displayName": "QuickRun",
  "description": "Save and run any terminal command from the VS Code sidebar in one click.",
  "version": "0.0.9",
  "publisher": "andrejschwanke",
  "license": "MIT",
  "icon": "assets/QuickRun_no_text_transparent.png",
  "homepage": "https://github.com/Paraaa/QuickRun#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Paraaa/QuickRun"
  },
  "bugs": {
    "url": "https://github.com/Paraaa/QuickRun/issues"
  },
  "keywords": [
    "commands",
    "terminal",
    "run",
    "shortcuts",
    "productivity"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "quickrun.addCommand",
        "title": "QuickRun: Add Command",
        "icon": "$(add)"
      },
      {
        "command": "quickrun.refreshCommands",
        "title": "QuickRun: Refresh Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "quickrun.executeCommand",
        "title": "QuickRun: Run Command",
        "icon": "$(play)"
      },
      {
        "command": "quickrun.editCommand",
        "title": "QuickRun: Edit Command",
        "icon": "$(edit)"
      },
      {
        "command": "quickrun.deleteCommand",
        "title": "QuickRun: Delete Command",
        "icon": "$(trash)"
      },
      {
        "command": "quickrun.focusTerminal",
        "title": "QuickRun: Focus Terminal"
      },
      {
        "command": "quickrun.stopCommand",
        "title": "QuickRun: Stop Command",
        "icon": "$(stop-circle)"
      },
      {
        "command": "quickrun.deleteGroup",
        "title": "QuickRun: Delete Group",
        "icon": "$(trash)"
      },
      {
        "command": "quickrun.addGroup",
        "title": "QuickRun: Add Group",
        "icon": "$(file-add)"
      },
      {
        "command": "quickrun.editGroup",
        "title": "QuickRun: Edit Group",
        "icon": "$(edit)"
      },
      {
        "command": "quickrun.runFromPalette",
        "title": "QuickRun: Run Command..."
      },
      {
        "command": "quickrun.autoSetup",
        "title": "QuickRun: Auto-Setup Project",
        "icon": "$(sparkle)"
      },
      {
        "command": "quickrun.autoSetupRecheck",
        "title": "QuickRun: Check for New Commands",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quickrunPanel",
          "title": "QuickRun",
          "icon": "assets/logo_dark_transparent.png"
        }
      ]
    },
    "views": {
      "quickrunPanel": [
        {
          "id": "quickrunPanel",
          "name": "QuickRun",
          "icon": "assets/logo_dark_transparent.png"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "quickrunPanel",
        "contents": "No commands yet.\n[Auto-Setup from project](command:quickrun.autoSetup)\nor [Add a command manually](command:quickrun.addCommand)."
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "quickrun.executeCommand",
          "when": "false"
        },
        {
          "command": "quickrun.editCommand",
          "when": "false"
        },
        {
          "command": "quickrun.deleteCommand",
          "when": "false"
        },
        {
          "command": "quickrun.deleteGroup",
          "when": "false"
        },
        {
          "command": "quickrun.editGroup",
          "when": "false"
        },
        {
          "command": "quickrun.focusTerminal",
          "when": "false"
        },
        {
          "command": "quickrun.stopCommand",
          "when": "false"
        },
        {
          "command": "quickrun.refreshCommands",
          "when": "false"
        },
        {
          "command": "quickrun.autoSetup",
          "when": "false"
        },
        {
          "command": "quickrun.autoSetupRecheck",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "quickrun.addCommand",
          "when": "view == quickrunPanel",
          "group": "navigation@1"
        },
        {
          "command": "quickrun.addGroup",
          "when": "view == quickrunPanel",
          "group": "navigation@2"
        },
        {
          "command": "quickrun.refreshCommands",
          "when": "view == quickrunPanel",
          "group": "navigation@3"
        },
        {
          "command": "quickrun.autoSetup",
          "when": "view == quickrunPanel",
          "group": "navigation@4"
        },
        {
          "command": "quickrun.autoSetupRecheck",
          "when": "view == quickrunPanel",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "quickrun.executeCommand",
          "when": "view == quickrunPanel && viewItem == commandItem",
          "group": "inline@1"
        },
        {
          "command": "quickrun.stopCommand",
          "when": "view == quickrunPanel && viewItem == commandItemRunning",
          "group": "inline@1"
        },
        {
          "command": "quickrun.editCommand",
          "when": "view == quickrunPanel && viewItem =~ /commandItem/",
          "group": "inline@2"
        },
        {
          "command": "quickrun.deleteCommand",
          "when": "view == quickrunPanel && viewItem =~ /commandItem/",
          "group": "inline@3"
        },
        {
          "command": "quickrun.addCommand",
          "when": "view == quickrunPanel && viewItem == group",
          "group": "inline@1"
        },
        {
          "command": "quickrun.editGroup",
          "when": "view == quickrunPanel && viewItem == group",
          "group": "inline@2"
        },
        {
          "command": "quickrun.deleteGroup",
          "when": "view == quickrunPanel && viewItem == group",
          "group": "inline@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "quickrunPanel.focus",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q"
      }
    ],
    "configuration": {
      "title": "QuickRun",
      "properties": {
        "quickrun.global": {
          "type": "object",
          "description": "Global QuickRun commands and groups stored in VS Code settings, available across all workspaces.",
          "default": {
            "commands": [],
            "groups": []
          },
          "properties": {
            "commands": {
              "type": "array",
              "description": "Global commands available in all workspaces.",
              "items": {
                "type": "object",
                "required": [
                  "label",
                  "customCommand"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "customCommand": {
                    "type": "string"
                  },
                  "icon": {
                    "type": "string"
                  },
                  "groupId": {
                    "type": "string"
                  }
                }
              }
            },
            "groups": {
              "type": "array",
              "description": "Global groups available in all workspaces.",
              "items": {
                "type": "object",
                "required": [
                  "label"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "icon": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "publish:ovsx": "node scripts/publish.js ovsx",
    "publish:vscode": "node scripts/publish.js vscode"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
